# Server Configuration
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/bizreply
JWT_SECRET=super_secret_jwt_token_for_bizreply_platform

# Mock Mode Configuration
# Set to 'true' to mock Anthropic Claude and Meta WhatsApp APIs during testing/development
MOCK_SERVICES=true

# WhatsApp / Meta Credentials (not needed if MOCK_SERVICES=true)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_WEBHOOK_VERIFY_TOKEN=your_custom_webhook_verify_token
WHATSAPP_API_TOKEN=your_meta_system_user_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# Anthropic Claude API Credentials (not needed if MOCK_SERVICES=true)
ANTHROPIC_API_KEY=your_anthropic_claude_api_key

# Razorpay Subscriptions (not needed if MOCK_SERVICES=true)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Redis for Broadcast Queue (optional - will fall back to in-memory if empty)
REDIS_URL=redis://127.0.0.1:6379
